# ===========================================
# CLIENT-SIDE ENVIRONMENT VARIABLES
# These are exposed to the browser (VITE_ prefix)
# ===========================================

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# ===========================================
# SERVER-SIDE ENVIRONMENT VARIABLES
# These are only available in API routes (Vercel Functions)
# ===========================================

# Supabase (service role for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Places API (for AI enrichment)
GOOGLE_PLACES_API_KEY=your_google_api_key

# Yelp Fusion API (fallback for enrichment)
YELP_API_KEY=your_yelp_api_key

# Vercel Blob Storage (for storing fetched images)
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Admin password (protects /admin area)
ADMIN_PASSWORD=your_admin_password
